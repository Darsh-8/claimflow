# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git!

DATABASE_URL=sqlite:///./claimflow.db
UPLOAD_DIR=./uploads

# Passwords for seeded demo accounts (never commit real passwords)
SEED_DEFAULT_PASSWORD=your-demo-password-here
SEED_ADMIN_PASSWORD=your-admin-password-here
KIMI_API_KEY=your-kimi-api-key-here
KIMI_API_URL=https://bedrock-runtime.us-west-2.amazonaws.com/model/moonshotai.kimi-k2.5/invoke
KIMI_MODEL_NAME=moonshotai.kimi-k2.5
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-west-2
